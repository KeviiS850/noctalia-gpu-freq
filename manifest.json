{
  "id": "gpu-freq",
  "name": "GPU Frequency",
  "description": "Real-time Intel iGPU frequency and utilization monitor. Reads gt_cur / act / min / max / boost frequencies from /sys/class/drm and renders as a compact bar pill with a hover-able details tooltip.",
  "tags": ["system", "monitor", "gpu", "intel", "frequency", "utilization"],
  "author": "keviis850",
  "homepage": "https://github.com/KeviiS850/noctalia-gpu-freq",
  "license": "MIT",
  "version": "0.2.0",
  "minNoctaliaVersion": "4.7.6",
  "icon": "device-desktop",
  "category": "system",
  "entryPoints": {
    "barWidget": "BarWidget.qml",
    "main": "Main.qml",
    "panel": "Panel.qml",
    "settings": "PluginSettings.qml"
  },
  "metadata": {
    "defaultSettings": {
      "gpuCard": "card1",
      "autoDetectCard": true,
      "showMax": true,
      "showMin": false,
      "showBoost": false,
      "showUtil": true,
      "pollIntervalMs": 1500
    }
  }
}
